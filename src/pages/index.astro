    min-width: 280px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .hero-banner {
    width: 100%;
    max-width: 520px;
    border-radius: 16px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
    transition: transform 0.3s ease;
  }
  .hero-banner:hover { transform: scale(1.02); }
  .hero-badge {
