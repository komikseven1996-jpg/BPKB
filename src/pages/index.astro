    --black: #1F2937;
    --white: #ffffff;
    --gray: #5B6472;
    --light-gray: #F4F6FB;
    --cream: #FAFAF7;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  img { max-width: 100%; height: auto; display: block; }

  html { scroll-behavior: smooth; }

  body {
