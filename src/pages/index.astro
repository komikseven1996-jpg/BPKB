---
const siteTitle = "Pinjaman Dana Cepat Jaminan BPKB Motor & Mobil | Cair Hari Ini";
const siteDescription = "Ajukan pinjaman dana cepat dengan jaminan BPKB motor dan mobil. Proses mudah, bunga ringan, dan pencairan cepat via WhatsApp.";
const siteKeywords = "pinjaman jaminan bpkb, gadai bpkb motor, gadai bpkb mobil, pinjaman dana tunai bpkb, pinjaman bpkb cepat cair, jaminan bpkb tanpa ribet, dana tunai jaminan bpkb, pinjaman bpkb bunga rendah, gadai bpkb terdekat, pinjaman jaminan kendaraan, kredit dana bpkb, pinjaman bpkb online, dana cepat cair bpkb, pinjaman bpkb legal, gadai bpkb resmi";
const siteUrl = "https://pinjamanbpkbcepat.com/";
const waNumber = "6281269146446";
const waMessage = encodeURIComponent("Halo, saya tertarik mengajukan pinjaman dengan jaminan BPKB.");
const waLink = `https://wa.me/${waNumber}?text=${waMessage}`;
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{siteTitle}</title>
  <meta name="description" content={siteDescription} />
  <meta name="keywords" content={siteKeywords} />
  <meta name="author" content="Pinjaman BPKB Cepat" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={siteUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={siteDescription} />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:locale" content="id_ID" />
  <meta property="og:site_name" content="Pinjaman BPKB Cepat" />
  <meta property="og:image" content={`${siteUrl}og-image.jpg`} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={siteTitle} />
  <meta name="twitter:description" content={siteDescription} />
  <meta name="twitter:image" content={`${siteUrl}og-image.jpg`} />

  <!-- Geo/local SEO -->
  <meta name="geo.placename" content="Indonesia" />
  <meta name="geo.region" content="ID" />

  <!-- Preconnect fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Hidden but crawlable structured keyword content for SEO (screen-reader only, not visible) -->
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FinancialService",
    "name": "Pinjaman BPKB Cepat",
    "description": siteDescription,
    "url": siteUrl,
    "areaServed": "ID",
    "serviceType": "Pinjaman dengan jaminan BPKB motor dan mobil",
    "telephone": "+" + waNumber,
    "priceRange": "Rp3.000.000 - Rp300.000.000"
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Apakah BPKB ditahan?",
        "acceptedAnswer": { "@type": "Answer", "text": "Ya, BPKB akan disimpan sebagai jaminan selama masa pinjaman berlangsung, dan akan dikembalikan setelah pelunasan." }
      },
      {
        "@type": "Question",
        "name": "Berapa lama proses pencairan?",
        "acceptedAnswer": { "@type": "Answer", "text": "Proses pencairan dana rata-rata hanya membutuhkan waktu beberapa jam setelah survey kendaraan selesai dan disetujui." }
      },
      {
        "@type": "Question",
        "name": "Apakah motor/mobil masih bisa dipakai?",
        "acceptedAnswer": { "@type": "Answer", "text": "Ya, kendaraan tetap bisa digunakan sehari-hari karena yang dijadikan jaminan hanya BPKB, bukan unit kendaraannya." }
      }
    ]
  })} />
</head>
<body>

  <!-- ================= HERO ================= -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <h1>Pinjaman Dana Cepat Jaminan BPKB Motor &amp; Mobil</h1>
        <p class="subtitle">Proses cepat, syarat mudah, dana cair dalam hitungan jam.</p>
        <a href={waLink} target="_blank" rel="noopener" class="btn-cta">Ajukan Sekarang</a>
      </div>
      <div class="hero-illustration" aria-hidden="true">
        <svg viewBox="0 0 400 260" xmlns="http://www.w3.org/2000/svg" class="vehicle-svg">
          <!-- Mobil -->
          <g>
            <rect x="30" y="120" width="180" height="55" rx="12" fill="#ffffff"/>
            <path d="M50 120 L75 85 H165 L190 120 Z" fill="#ffffff"/>
            <rect x="95" y="95" width="55" height="25" rx="4" fill="#3B5FE0"/>
            <circle cx="70" cy="178" r="18" fill="#1F2937"/>
            <circle cx="170" cy="178" r="18" fill="#1F2937"/>
            <circle cx="70" cy="178" r="7" fill="#3B5FE0"/>
            <circle cx="170" cy="178" r="7" fill="#3B5FE0"/>
          </g>
          <!-- Motor -->
          <g transform="translate(210,0)">
            <circle cx="30" cy="185" r="22" fill="none" stroke="#ffffff" stroke-width="6"/>
            <circle cx="140" cy="185" r="22" fill="none" stroke="#ffffff" stroke-width="6"/>
            <path d="M30 185 L70 140 H100 L140 185" stroke="#ffffff" stroke-width="6" fill="none"/>
            <path d="M70 140 L90 110" stroke="#ffffff" stroke-width="6" fill="none"/>
            <rect x="95" y="128" width="35" height="12" rx="4" fill="#3B5FE0"/>
          </g>
        </svg>
      </div>
    </div>
  </section>

  <!-- ================= KEUNGGULAN ================= -->
  <section class="section keunggulan">
    <div class="container">
      <h2>Kenapa Pilih Kami?</h2>
      <div class="grid-4">
        <div class="card">
          <div class="icon">⚡</div>
          <h3>Proses Cepat</h3>
          <p>Pengajuan mudah dan dana cair hanya dalam hitungan jam setelah survey.</p>
        </div>
        <div class="card">
          <div class="icon">💰</div>
          <h3>Bunga Kompetitif</h3>
          <p>Bunga ringan dan transparan tanpa biaya tersembunyi.</p>
        </div>
        <div class="card">
          <div class="icon">🚗</div>
          <h3>Semua Merek Diterima</h3>
          <p>Semua merek dan tahun motor maupun mobil dapat diajukan.</p>
        </div>
        <div class="card">
          <div class="icon">📋</div>
          <h3>Survey &amp; Pencairan Mudah</h3>
          <p>Survey cepat langsung ke lokasi, pencairan dana tanpa ribet.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= SIMULASI PINJAMAN ================= -->
  <section class="section simulasi">
    <div class="container">
      <h2>Simulasi Plafon Pinjaman</h2>
      <div class="grid-2">
        <div class="card sim-card">
          <h3>🏍️ Jaminan BPKB Motor</h3>
          <p class="sim-amount">Rp3.000.000 &mdash; Rp50.000.000</p>
          <p>Plafon disesuaikan dengan tahun dan kondisi kendaraan.</p>
        </div>
        <div class="card sim-card">
          <h3>🚙 Jaminan BPKB Mobil</h3>
          <p class="sim-amount">Rp10.000.000 &mdash; Rp300.000.000</p>
          <p>Plafon lebih besar untuk kebutuhan dana yang lebih besar.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= PERSYARATAN ================= -->
  <section class="section persyaratan">
    <div class="container">
      <h2>Persyaratan Pengajuan</h2>
      <ul class="req-list">
        <li>✔ Fotokopi KTP</li>
        <li>✔ BPKB Asli</li>
        <li>✔ STNK</li>
        <li>✔ Kendaraan Atas Nama Sendiri / Keluarga</li>
      </ul>
    </div>
  </section>

  <!-- ================= CARA PENGAJUAN ================= -->
  <section class="section cara-pengajuan">
    <div class="container">
      <h2>Cara Pengajuan</h2>
      <div class="steps">
        <div class="step">
          <div class="step-number">1</div>
          <h3>Hubungi WhatsApp</h3>
          <p>Klik tombol WhatsApp dan sampaikan kebutuhan pinjaman Anda.</p>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <h3>Konsultasi Plafon</h3>
          <p>Tim kami akan membantu menghitung estimasi plafon pinjaman.</p>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <h3>Survey Kendaraan</h3>
          <p>Petugas datang untuk melakukan pengecekan kendaraan.</p>
        </div>
        <div class="step">
          <div class="step-number">4</div>
          <h3>Dana Cair</h3>
          <p>Setelah disetujui, dana langsung ditransfer ke rekening Anda.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= TESTIMONI ================= -->
  <section class="section testimoni">
    <div class="container">
      <h2>Apa Kata Mereka</h2>
      <div class="grid-3">
        <div class="card testi-card">
          <p>"Prosesnya cepat banget, cuma dalam hari yang sama dana langsung cair. Sangat membantu!"</p>
          <span class="testi-name">— Budi, Jakarta</span>
        </div>
        <div class="card testi-card">
          <p>"Bunga ringan dan pelayanannya ramah. Motor saya juga tetap bisa dipakai sehari-hari."</p>
          <span class="testi-name">— Siti, Bandung</span>
        </div>
        <div class="card testi-card">
          <p>"Survey mobil cepat, dokumen simpel, tidak ribet. Recommended untuk kebutuhan dana mendesak."</p>
          <span class="testi-name">— Andi, Surabaya</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= FAQ ================= -->
  <section class="section faq">
    <div class="container">
      <h2>Pertanyaan Umum</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>Apakah BPKB ditahan?</summary>
          <p>Ya, BPKB akan disimpan sebagai jaminan selama masa pinjaman berlangsung, dan akan dikembalikan setelah pelunasan.</p>
        </details>
        <details class="faq-item">
          <summary>Berapa lama proses pencairan?</summary>
          <p>Proses pencairan dana rata-rata hanya membutuhkan waktu beberapa jam setelah survey kendaraan selesai dan disetujui.</p>
        </details>
        <details class="faq-item">
          <summary>Apakah motor/mobil masih bisa dipakai?</summary>
          <p>Ya, kendaraan tetap bisa digunakan sehari-hari karena yang dijadikan jaminan hanya BPKB, bukan unit kendaraannya.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- ================= FOOTER ================= -->
  <footer class="footer">
    <div class="container">
      <p class="footer-name">Pinjaman BPKB Cepat</p>
      <p>&copy; {new Date().getFullYear()} Pinjaman BPKB Cepat. Seluruh hak cipta dilindungi.</p>
    </div>
  </footer>

  <!-- Hidden SEO text block (visually hidden, still crawlable) -->
  <p class="visually-hidden">
    Layanan pinjaman jaminan BPKB motor dan mobil, gadai BPKB terpercaya, dana tunai cepat cair,
    pinjaman jaminan kendaraan bunga rendah, solusi kebutuhan dana mendesak dengan jaminan BPKB resmi dan legal.
  </p>

  <!-- ================= WHATSAPP FLOATING BUTTON ================= -->
  <a href={waLink} target="_blank" rel="noopener" class="wa-float" aria-label="Chat WhatsApp">
    <svg viewBox="0 0 32 32" width="30" height="30" fill="#ffffff">
      <path d="M16.001 3C9.373 3 4 8.373 4 15c0 2.31.65 4.47 1.78 6.31L4 29l7.86-1.75C13.63 28.06 14.79 28.3 16 28.3c6.627 0 12-5.373 12-12S22.628 3 16.001 3zm.028 21.6c-1.14 0-2.26-.24-3.29-.7l-.236-.11-4.66 1.04 1.02-4.55-.15-.24A9.55 9.55 0 0 1 6.6 15c0-5.19 4.21-9.4 9.43-9.4 5.21 0 9.42 4.21 9.42 9.4 0 5.2-4.21 9.6-9.42 9.6zm5.17-7.05c-.28-.14-1.66-.82-1.92-.91-.26-.1-.45-.14-.64.14-.19.28-.73.91-.9 1.1-.16.19-.33.21-.61.07-.28-.14-1.18-.44-2.24-1.39-.83-.74-1.39-1.65-1.55-1.93-.16-.28-.02-.43.12-.57.13-.13.28-.33.42-.5.14-.16.19-.28.28-.47.09-.19.05-.35-.02-.5-.07-.14-.64-1.55-.88-2.12-.23-.56-.47-.48-.64-.49h-.55c-.19 0-.5.07-.76.35-.26.28-1 1-1 2.42 0 1.42 1.02 2.8 1.16 3 .14.19 2 3.04 4.84 4.27.68.29 1.2.47 1.61.6.68.22 1.29.19 1.78.11.54-.08 1.66-.68 1.9-1.34.23-.66.23-1.22.16-1.34-.07-.12-.26-.19-.54-.33z"/>
    </svg>
  </a>

</body>
</html>

<style>
  :root {
    --red: #3B5FE0;
    --red-dark: #1E3A8A;
    --black: #1F2937;
    --white: #ffffff;
    --gray: #5B6472;
    --light-gray: #F4F6FB;
    --cream: #FAFAF7;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--black);
    background: var(--cream);
    line-height: 1.6;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  /* HERO */
  .hero {
    background: linear-gradient(135deg, var(--black) 0%, var(--red-dark) 100%);
    color: var(--white);
    padding: 90px 0 70px;
  }
  .hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    flex-wrap: wrap;
  }
  .hero-text { flex: 1; min-width: 280px; }
  .hero-text h1 {
    font-size: 2.6rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 18px;
  }
  .subtitle {
    font-size: 1.15rem;
    color: #f1f1f1;
    margin-bottom: 30px;
    max-width: 480px;
  }
  .btn-cta {
    display: inline-block;
    background: var(--red);
    color: var(--white);
    font-weight: 700;
    padding: 16px 34px;
    border-radius: 8px;
    text-decoration: none;
    font-size: 1.05rem;
    transition: background 0.2s ease, transform 0.2s ease;
    box-shadow: 0 8px 20px rgba(225,29,46,0.4);
  }
  .btn-cta:hover { background: #4F73F0; transform: translateY(-2px); }

  .hero-illustration { flex: 1; min-width: 260px; display: flex; justify-content: center; }
  .vehicle-svg { width: 100%; max-width: 420px; height: auto; }

  /* SECTIONS */
  .section { padding: 70px 0; }
  .section h2 {
    text-align: center;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 40px;
    color: var(--black);
  }

  .keunggulan { background: var(--light-gray); }

  .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .card {
    background: var(--white);
    border: 1px solid #eaeaea;
    border-radius: 14px;
    padding: 30px 24px;
    text-align: center;
    box-shadow: 0 4px 14px rgba(0,0,0,0.05);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .card:hover { transform: translateY(-4px); box-shadow: 0 10px 24px rgba(0,0,0,0.1); }

  .icon { font-size: 2.2rem; margin-bottom: 12px; }
  .card h3 { font-size: 1.15rem; margin-bottom: 10px; color: var(--black); }
  .card p { color: var(--gray); font-size: 0.95rem; }

  /* SIMULASI */
  .sim-card { text-align: left; border-top: 4px solid var(--red); }
  .sim-amount { font-size: 1.5rem; font-weight: 800; color: var(--red); margin: 10px 0; }

  /* PERSYARATAN */
  .req-list {
    list-style: none;
    max-width: 500px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .req-list li {
    background: var(--light-gray);
    padding: 16px 20px;
    border-radius: 10px;
    font-weight: 500;
  }

  /* CARA PENGAJUAN */
  .cara-pengajuan { background: var(--black); color: var(--white); }
  .cara-pengajuan h2 { color: var(--white); }
  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .step { text-align: center; }
  .step-number {
    width: 46px;
    height: 46px;
    background: var(--red);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.2rem;
    margin: 0 auto 14px;
  }
  .step h3 { margin-bottom: 8px; font-size: 1.05rem; }
  .step p { color: #cfcfcf; font-size: 0.9rem; }

  /* TESTIMONI */
  .testi-card p { font-style: italic; color: var(--black); margin-bottom: 16px; }
  .testi-name { font-weight: 700; color: var(--red); font-size: 0.9rem; }

  /* FAQ */
  .faq { background: var(--light-gray); }
  .faq-list { max-width: 700px; margin: 0 auto; display: flex; flex-direction: column; gap: 12px; }
  .faq-item {
    background: var(--white);
    border-radius: 10px;
    padding: 18px 20px;
    border: 1px solid #eaeaea;
  }
  .faq-item summary {
    font-weight: 700;
    cursor: pointer;
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: "+"; float: right; font-size: 1.2rem; color: var(--red); }
  .faq-item[open] summary::after { content: "−"; }
  .faq-item p { margin-top: 12px; color: var(--gray); }

  /* FOOTER */
  .footer {
    background: var(--black);
    color: #cfcfcf;
    text-align: center;
    padding: 34px 0;
    font-size: 0.9rem;
  }
  .footer-name { color: var(--white); font-weight: 700; font-size: 1.1rem; margin-bottom: 6px; }

  /* WHATSAPP FLOAT */
  .wa-float {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 58px;
    height: 58px;
    background: #25D366;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 18px rgba(0,0,0,0.25);
    z-index: 999;
    transition: transform 0.2s ease;
  }
  .wa-float:hover { transform: scale(1.08); }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .grid-4 { grid-template-columns: repeat(2, 1fr); }
    .steps { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .hero-text h1 { font-size: 2rem; }
    .grid-3, .grid-2 { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .grid-4 { grid-template-columns: 1fr; }
    .steps { grid-template-columns: 1fr; }
    .hero { padding: 60px 0 40px; }
  }
</style>
